# Primary API base for the Vite app (see also .env.development / .env.production templates).
# Database & server secrets: backend/.env — see backend/docs/DEPLOYMENT_ENVIRONMENT_RULES.md
VITE_API_URL="http://localhost:4000"
VITE_STRIPE_PUBLISHABLE_KEY=""
VITE_PAYSTACK_PUBLIC_KEY=""
VITE_SENTRY_DSN=""
VITE_SENTRY_ENVIRONMENT="development"
VITE_SENTRY_RELEASE=""
# Optional pilot support: full WhatsApp chat link for Help page (https://wa.me/...)
# VITE_SUPPORT_WHATSAPP_URL=""
# Optional GA4 (G-XXXXXXXX) — enables gtag + dataLayer page views and TrackedLink events
# VITE_GA_MEASUREMENT_ID=""
# Phase 8: use either GA4 direct OR GTM (not both unless you know your container)
# VITE_GTM_ID="GTM-XXXXXXX"
# Meta Pixel (numeric id) + Google Ads remarketing (AW-…)
# VITE_META_PIXEL_ID=""
# VITE_GOOGLE_ADS_ID=""

# SEO: canonical origin for OG URLs and JSON-LD (no trailing slash), e.g. https://posflyt.com
# VITE_SITE_URL="https://posflyt.com"
# Comma-separated social profile URLs for Organization sameAs (optional)
# VITE_ORG_SAME_AS="https://twitter.com/posflyt,https://www.facebook.com/posflyt"
