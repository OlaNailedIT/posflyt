# =============================================================================
# Database (Phase 5 — never commit real credentials; use platform secrets in prod)
# =============================================================================
# Development: local PostgreSQL (see .env.development template).
# Staging: isolated instance — separate USER/PASSWORD/DB from prod.
# Production: managed Postgres (TLS, network-restricted); rotate credentials on schedule.
#
# Standard shape (URL-encode special characters in USER/PASSWORD):
#   postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
# Production: use TLS query params as required by your host (e.g. ?sslmode=require&schema=public).
#
DATABASE_URL="postgresql://<USER>:<PASSWORD>@<HOST>:<PORT>/<DB_NAME>?schema=public"
#
# Shadow DB: empty database — never production data. Different DB name (and user/creds) from DATABASE_URL.
# Used by: migrate dev, drift-check, migrate diff --from-migrations. Not used by migrate deploy.
#
SHADOW_DATABASE_URL="postgresql://<USER>:<PASSWORD>@<HOST>:<PORT>/<SHADOW_DB_NAME>?schema=public"
#
# Optional read replica (same schema as primary):
# DATABASE_READ_URL="postgresql://<USER>:<PASSWORD>@<HOST>:<PORT>/<DB_NAME>?schema=public"
# Must be cryptographically random (≥64 chars recommended). Never reuse across dev/staging/prod.
# Generate (Node): node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Generate (OpenSSL): openssl rand -hex 48
JWT_SECRET="REPLACE_WITH_SECURE_RANDOM_64+_CHAR_STRING"
JWT_ISSUER="posflyt-api"
JWT_AUDIENCE="posflyt-client"
JWT_ACCESS_EXPIRES_IN="1h"
JWT_REFRESH_TTL_MS="2592000000"
PORT=4000
APP_BASE_URL="http://localhost:5173"
CORS_ORIGIN="http://localhost:5173"
LOG_LEVEL="info"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
PAYSTACK_SECRET_KEY=""
PAYSTACK_WEBHOOK_SECRET=""
# sandbox | live (for logs and future API calls; never commit real keys)
# BILLING_MODE=sandbox
# PAYMENT_RETRY_MAX_ATTEMPTS=5
# SLACK_BILLING_WEBHOOK_URL=
# Billing: optional FREE trial length (days) for new businesses only; 0 = no trial end date (default, safest).
# BILLING_TRIAL_DAYS=14
# Require configured webhook secrets (set false for local webhook testing without secrets).
# REQUIRE_BILLING_WEBHOOK_SIGNATURE=false
SENTRY_DSN=""
SENTRY_RELEASE=""
# Phase 7.1 observability (optional)
# SENTRY_TRACES_SAMPLE_RATE=0.1
# METRICS_ENABLED=true
# METRICS_BEARER_TOKEN=""
# Phase 7.4: behind a reverse proxy / load balancer (e.g. Render), set so rate limits use client IP
# TRUST_PROXY=1
# Grace after paid plan expiresAt before API blocks (days). 0 = no grace.
# SUBSCRIPTION_GRACE_PERIOD_DAYS=3
# In-app / Slack reminders when trial ends within N days (requires BILLING_TRIAL_DAYS > 0).
# TRIAL_WARNING_DAYS_BEFORE=3

# Phase 9: Redis (cache + BullMQ). Same URL for both.
# REDIS_URL="redis://localhost:6379"
# QUEUE_ENABLED=true
# Optional read replica — see DATABASE_READ_URL placeholder at top of this file.
# CACHE_TTL_SECONDS=45

# Phase 7 chaos engineering API (POST /api/v1/chaos/run). Off by default; admin JWT only.
# CHAOS_ENGINE_ENABLED=true
# In production, also set (dangerous): CHAOS_ENGINE_ALLOW_PRODUCTION=true

# Phase 8 — logical sharding + region id (single DB today; used for routing keys & future multi-region)
# LEDGER_SHARD_COUNT=4
# DEPLOYMENT_REGION_ID=local
# Optional per-tenant region hints JSON: {"<businessUuid>":"eu-west-1"}
# BUSINESS_REGION_MAP_JSON={}
# Optional comma-separated peer region ids for aggregation demos / future peer fetch (Phase 8.2).
# KNOWN_REGION_IDS=eu-west-1,us-east-1
# When true, reject integrity ingest if tenant home region (map/default) ≠ DEPLOYMENT_REGION_ID (Phase 8.3).
# STRICT_REGION_INGEST=false
# Future: per-region Prisma URLs — today only marks hasDedicatedPool; wiring is TBD.
# REGION_DATABASE_URLS_JSON={}

# Phase 8.7 — failover / aggregation (local process)
# Emergency: reject all integrity writes with 503 REGION_UNAVAILABLE.
# GLOBAL_WRITE_KILL_SWITCH=false
# This deployment stops accepting writes (same region as DEPLOYMENT_REGION_ID).
# DEPLOYMENT_REGION_READ_ONLY=false
# Override writability per region id (ops failover). Omitted keys use defaults below.
# REGION_WRITABLE_MAP_JSON={}
# When REGION_WRITABLE_MAP_JSON omits a peer region, default is writable unless:
# REGION_PEER_DEFAULT_WRITABLE=false
# Latency above this marks local region health as degraded (dashboards / aggregation).
# REGION_HEALTH_DEGRADED_LATENCY_MS=500
