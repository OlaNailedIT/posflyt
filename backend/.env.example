DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/POSflyt?schema=public"
JWT_SECRET="replace-with-strong-secret"
JWT_ISSUER="posflyt-api"
JWT_AUDIENCE="posflyt-client"
JWT_ACCESS_EXPIRES_IN="1h"
JWT_REFRESH_TTL_MS="2592000000"
PORT=4000
APP_BASE_URL="http://localhost:5173"
CORS_ORIGIN="http://localhost:5173"
LOG_LEVEL="info"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
PAYSTACK_SECRET_KEY=""
PAYSTACK_WEBHOOK_SECRET=""
# sandbox | live (for logs and future API calls; never commit real keys)
# BILLING_MODE=sandbox
# PAYMENT_RETRY_MAX_ATTEMPTS=5
# SLACK_BILLING_WEBHOOK_URL=
# Billing: optional FREE trial length (days) for new businesses only; 0 = no trial end date (default, safest).
# BILLING_TRIAL_DAYS=14
# Require configured webhook secrets (set false for local webhook testing without secrets).
# REQUIRE_BILLING_WEBHOOK_SIGNATURE=false
SENTRY_DSN=""
SENTRY_RELEASE=""
# Phase 7.1 observability (optional)
# SENTRY_TRACES_SAMPLE_RATE=0.1
# METRICS_ENABLED=true
# METRICS_BEARER_TOKEN=""
# Phase 7.4: behind a reverse proxy / load balancer (e.g. Render), set so rate limits use client IP
# TRUST_PROXY=1
# Grace after paid plan expiresAt before API blocks (days). 0 = no grace.
# SUBSCRIPTION_GRACE_PERIOD_DAYS=3
# In-app / Slack reminders when trial ends within N days (requires BILLING_TRIAL_DAYS > 0).
# TRIAL_WARNING_DAYS_BEFORE=3

# Phase 9: Redis (cache + BullMQ). Same URL for both.
# REDIS_URL="redis://localhost:6379"
# QUEUE_ENABLED=true
# Optional read replica for heavy SELECTs (same schema as DATABASE_URL).
# DATABASE_READ_URL="postgresql://reader:pass@replica:5432/POSflyt?schema=public"
# CACHE_TTL_SECONDS=45
