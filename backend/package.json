{
  "name": "backend",
  "version": "1.0.0",
  "description": "POSflyt SaaS POS + ERP backend",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "worker": "node src/jobs/worker.js",
    "predeploy": "node scripts/predeploy-check.js",
    "start:prod": "node scripts/predeploy-check.js && node scripts/prisma-safety-check.js prisma migrate deploy && node src/server.js",
    "test": "node --test test/health.test.js test/metrics-runtime.test.js test/sanitize.test.js test/paymentState.test.js test/expenseService.test.js test/splitPayments.test.js test/productUnits.test.js test/lowStock.test.js test/auditEventSchema.test.js test/ufecClientEnforcement.test.mjs",
    "test:integration": "node --test test/auth.integration.test.js test/settings-admin.integration.test.js test/crm-report-receipt.integration.test.js test/analytics-onboarding.integration.test.js test/sync-reliability.integration.test.js test/credit-sales.integration.test.js test/expense.integration.test.js test/multi-payment.integration.test.js test/weighted-products.integration.test.js",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:drift-check": "bash scripts/prisma-drift-check.sh",
    "prisma:drift-check:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prisma-drift-check.ps1",
    "prisma:migrate": "node scripts/prisma-safety-check.js prisma migrate deploy",
    "prisma:deploy": "node scripts/prisma-safety-check.js prisma migrate deploy",
    "prisma:migrate-dev": "node scripts/prisma-safety-check.js prisma migrate dev",
    "prisma:reset": "node scripts/prisma-safety-check.js prisma migrate reset",
    "prisma:db-push-dev": "node scripts/prisma-safety-check.js prisma db push",
    "prisma:recovery": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prisma-recovery.ps1",
    "seed": "prisma db seed",
    "audit:integrity": "node scripts/auditFinancialIntegrity.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=20 <21"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^10.47.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.58.0",
    "compression": "^1.8.1",
    "connect-timeout": "^1.9.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pdfkit": "^0.15.2",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "^5.22.0",
    "rate-limit-redis": "^4.3.1",
    "stripe": "^17.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "supertest": "^7.1.0"
  }
}
