generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id             String              @id @default(uuid())
  name           String
  createdAt      DateTime            @default(now())
  auditLogs      AuditLog[]
  backups        BackupRecord[]
  customers      Customer[]
  issues         IssueReport[]
  onboarding     OnboardingProgress?
  paymentHistory PaymentHistory[]
  products       Product[]
  lowStockAlertDays LowStockAlertDay[]
  settings       Settings?
  smartAlerts    SmartAlert[]
  stores         Store[]
  subscription   Subscription?
  transactions   Transaction[]
  expenses       Expense[]
  usageMonthly   UsageMonthly[]
  users          User[]
  dailyCloses    DailyClose[]
  saleReturns    SaleReturn[]
  ledgerEntries  FinancialLedgerEntry[]
  /// Phase 4 SoR: append-only ingested integrity events (distinct from FinancialLedgerEntry).
  integrityLedgerEvents IntegrityLedgerEvent[]
  integrityLedgerLines  IntegrityLedgerLine[]
  /// Phase 5: derived materialized view of integrity state (events remain SoR).
  integritySnapshots    IntegritySnapshot[]
  staffInvites         StaffInvite[]
  /// Append-only business accountability events (synced from client outbox; not UFEC financial ledger).
  auditTrailEvents     AuditEvent[]
}

/// Phase 7.13.1: operational daily close log (not full accounting).
model DailyClose {
  id             String   @id @default(uuid())
  businessId     String
  userId         String
  totalSales     Float
  startOfDay     DateTime
  endOfDay       DateTime
  closedAt       DateTime @default(now())
  /// YYYY-MM-DD in business time zone (idempotency: one close per business day).
  businessDayKey String

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([businessId, businessDayKey])
  @@index([businessId])
  @@index([userId])
  @@index([closedAt(sort: Desc)])
}

/// Phase 7.10.2: simple business expenses; DPE uses expenseDate for calendar-day rolls (defaults to created day).
model Expense {
  id         String   @id @default(cuid())
  businessId String
  amount     Float
  category   String
  note       String?
  /// Calendar expense date (defaults to creation day); used for daily net profit vs business time zone.
  expenseDate DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  requestId  String?  @unique
  eventId    String?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, eventId])
  @@index([businessId])
  @@index([createdAt])
  @@index([businessId, expenseDate])
}

model User {
  id            String          @id @default(uuid())
  name          String
  email         String          @unique
  /// E.164-style digits only (e.g. 2348012345678); set for WhatsApp invite staff; login with phone + PIN.
  phone         String?         @unique
  password      String
  role          Role            @default(CASHIER)
  createdAt     DateTime        @default(now())
  businessId    String
  sessions      ActiveSession[]
  auditLogs     AuditLog[]
  issues        IssueReport[]
  refreshTokens RefreshToken[]
  transactions  Transaction[]
  dailyCloses   DailyClose[]
  saleReturns   SaleReturn[]
  integrityLedgerEvents IntegrityLedgerEvent[]
  business      Business        @relation(fields: [businessId], references: [id])

  @@index([businessId])
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  sessionJti String?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Store {
  id           String        @id @default(uuid())
  name         String
  location     String?
  createdAt    DateTime      @default(now())
  businessId   String
  products     Product[]
  business     Business      @relation(fields: [businessId], references: [id])
  transactions Transaction[]
  staffInvites StaffInvite[]

  @@index([businessId])
}

/// One-time WhatsApp / link invite for staff to set PIN and create an account (no password email flow).
model StaffInvite {
  id         String   @id @default(uuid())
  businessId String
  /// Normalized phone digits (same format as User.phone).
  phone      String
  fullName   String
  role       Role
  token      String   @unique
  expiresAt  DateTime
  used       Boolean  @default(false)
  storeId    String?
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  store    Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([businessId, phone])
}

model Product {
  id                String            @id
  name              String
  costPrice         Float             @default(0)
  sellingPrice      Float             @default(0)
  price             Float
  /// Phase 7.11.1: "unit" = discrete count; "kg" | "litre" = sold by weight/volume (fractional qty).
  unitType          String            @default("unit")
  /// Price per kg/litre when unitType is not "unit"; null for discrete products.
  pricePerUnit      Float?
  stock             Float
  /// Phase 7.11.3: alert when stock <= threshold; null or ≤0 = no alert for this product.
  lowStockThreshold Float?
  barcode           String?           @unique
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  businessId        String
  storeId           String?
  business          Business          @relation(fields: [businessId], references: [id])
  store             Store?            @relation(fields: [storeId], references: [id])
  transactionItems  TransactionItem[]
  lowStockAlertDays LowStockAlertDay[]

  @@index([businessId])
}

/// Phase 7.11.3: one dedupe row per product per UTC day when a low-stock alert fires (transaction or scan).
model LowStockAlertDay {
  id          String   @id @default(cuid())
  businessId  String
  productId   String
  dayUtc      String
  stock       Float
  threshold   Float
  source      String
  createdAt   DateTime @default(now())
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([businessId, productId, dayUtc])
  @@index([businessId])
}

model Customer {
  id               String        @id @default(uuid())
  name             String
  email            String?
  phone            String?
  createdAt        DateTime      @default(now())
  businessId       String
  updatedAt        DateTime      @default(now()) @updatedAt
  /// Sum of unpaid balances from credit / partial sales (server-maintained).
  totalOutstanding Float         @default(0)
  /// Idempotency key for aggregate settle (POST /customers/:id/settle-credit).
  lastCreditSettlementRequestId String?
  business         Business      @relation(fields: [businessId], references: [id])
  transactions     Transaction[]

  @@index([businessId])
}

/// UFEC: Payment/totals below (`transactionType`, `amountPaid`, `balanceDue`) are persisted denormalization.
/// Canonical financial state for UFEC flows is enforced in the ledger / event layer; DB CHECKs on these
/// columns were removed (see neutralized migrations under `prisma/migrations/202604*` overrides).
model Transaction {
  id            String            @id
  /// Sum of line totals before tax (legacy rows may be null; backfilled in migration).
  subtotalAmount Float?
  /// Tax portion of the sale (legacy backfilled as totalAmount - subtotal).
  taxAmount     Float             @default(0)
  /// SALE (default) or RETURN (manager flow; reverses stock).
  transactionType TransactionType @default(SALE)
  /// When transactionType is RETURN, links to the original sale.
  originalTransactionId String?
  originalTransaction   Transaction?  @relation("TransactionReturn", fields: [originalTransactionId], references: [id], onDelete: SetNull)
  returnOf              Transaction[] @relation("TransactionReturn")
  saleReturnOriginals   SaleReturn[]  @relation("SaleReturnOriginal")
  saleReturnMirrors     SaleReturn[]  @relation("SaleReturnMirror")
  /// Sale total (line items + tax); amountPaid/balanceDue are app-layer denormalization (no DB CHECKs; UFEC).
  totalAmount   Float
  /// DPE: sum of line COGS at sale time (RETURN rows negative when restated from lines).
  totalCogs      Float?
  /// DPE: sum of line (revenue − COGS) on subtotal basis before operating expenses.
  grossLineProfit Float?
  /// Phase 7.10.4: split tender lines; sum of amounts equals totalAmount when set. Legacy rows null.
  payments      Json?
  paymentMethod PaymentMethod
  /// Sale payment lifecycle (distinct from billing PaymentHistory.status enum).
  paymentStatus TransactionPaymentStatus @default(PAID)
  amountPaid    Float             @default(0)
  balanceDue    Float             @default(0)
  dueDate       DateTime?
  createdAt     DateTime
  updatedAt     DateTime          @updatedAt
  syncedAt      DateTime?
  syncStatus    SyncStatus        @default(PENDING)
  /// Duplicate replay guard for credit settlement sync.
  lastSettlementRequestId String?
  /// Offline / sync event deduplication (optional client-provided id).
  lastProcessedEventId    String?
  /// SHA-256 hex of canonical sale body (same id → same hash; duplicate with mismatch → 409).
  payloadHash               String?
  /// Phase 7.12.1: receipt PDF id (filename base in storage).
  receiptId          String? @unique
  /// Shareable URL (API public route or hosted PDF).
  receiptUrl         String?
  /// Opaque token for unauthenticated GET /receipts/public/:token.
  receiptPublicToken String? @unique
  businessId    String
  userId        String
  storeId       String?
  customerId    String?
  business      Business          @relation(fields: [businessId], references: [id])
  customer      Customer?         @relation(fields: [customerId], references: [id])
  store         Store?            @relation(fields: [storeId], references: [id])
  user          User              @relation(fields: [userId], references: [id])
  items         TransactionItem[]
  /// Phase 4 SoR ledger linkage (optional until sync completes).
  integrityLedgerEvents IntegrityLedgerEvent[]
  integrityLedgerLines  IntegrityLedgerLine[]

  @@unique([id, businessId], map: "Transaction_client_transaction_id_business_id_key")
  @@index([businessId])
  @@index([businessId, createdAt(sort: Desc)])
}

/// Financial-grade return orchestration (idempotent on clientReturnId; resumable state machine).
model SaleReturn {
  id                    String           @id @default(cuid())
  businessId            String
  userId                String
  /// Idempotency key from client (same as mirror Transaction.id when completed).
  clientReturnId        String
  originalTransactionId String
  state                 SaleReturnState    @default(RETURN_INITIATED)
  /// Mirror RETURN transaction row (created last in pipeline).
  returnTransactionId   String?          @unique
  failureCode           String?
  failureDetail         String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  business              Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user                  User             @relation(fields: [userId], references: [id])
  originalTransaction   Transaction      @relation("SaleReturnOriginal", fields: [originalTransactionId], references: [id], onDelete: Restrict)
  returnTransaction     Transaction?     @relation("SaleReturnMirror", fields: [returnTransactionId], references: [id], onDelete: SetNull)
  lines                 SaleReturnLine[]
  ledgerEntry           FinancialLedgerEntry?

  @@unique([businessId, clientReturnId])
  @@index([businessId, originalTransactionId])
  @@index([businessId, state])
}

model SaleReturnLine {
  id           String     @id @default(cuid())
  saleReturnId String
  productId    String
  quantity     Float
  saleReturn   SaleReturn @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)

  @@index([saleReturnId])
  @@index([productId])
}

/// Append-only financial corrections (returns). Source of truth for reversal amounts before mirror Transaction row.
model FinancialLedgerEntry {
  id                    String          @id @default(cuid())
  businessId            String
  kind                  LedgerEntryKind
  saleReturnId          String          @unique
  originalTransactionId String
  subtotalAmount        Float
  taxAmount             Float
  totalAmount           Float
  metadata              Json?
  createdAt             DateTime        @default(now())

  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  saleReturn SaleReturn @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt(sort: Desc)])
  @@index([originalTransactionId])
}

/// Phase 4 system-of-record: immutable append-only **ingested** events (reconcile / audit).
/// Not to be confused with `FinancialLedgerEntry` (return-reversal ledger only).
model IntegrityLedgerEvent {
  /// Idempotency key from client (e.g. UUID); one row per successful ingest.
  eventId             String      @id
  businessId          String
  /// Stable client execution id (often equals `Transaction.id` once synced).
  clientTransactionId String
  /// Populated when the canonical `Transaction` row exists.
  transactionId       String?
  /// Logical event type (e.g. SALE_APPLIED, OFFLINE_QUEUED).
  type                String
  payload             Json
  payloadHash         String
  source              LedgerIntegritySource
  userId              String?
  /// Client-supplied monotonic-ish time (ms) for deterministic replay ordering; falls back to createdAt when null.
  clientTimestampMs   BigInt?
  createdAt           DateTime    @default(now())

  business     Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transaction  Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  ledgerLines  IntegrityLedgerLine[]

  @@index([businessId, clientTransactionId])
  @@index([businessId, clientTransactionId, clientTimestampMs, eventId])
  @@index([businessId, createdAt(sort: Desc)])
}

/// Phase 4 system-of-record: append-only **derived** ledger lines (projection; no in-place updates).
model IntegrityLedgerLine {
  ledgerLineId        String                 @id
  businessId          String
  clientTransactionId String
  transactionId       String?
  debit               Float
  credit              Float
  lineKind            IntegrityLedgerLineKind
  /// Originating integrity event when applicable.
  sourceEventId       String?
  balanceAfter        Float
  createdAt           DateTime               @default(now())

  business    Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transaction Transaction?         @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  sourceEvent IntegrityLedgerEvent? @relation(fields: [sourceEventId], references: [eventId], onDelete: SetNull)

  @@index([businessId, clientTransactionId])
  @@index([businessId, transactionId])
  @@index([sourceEventId])
}

/// Phase 5: checkpoint of replayed integrity financial state (cache only; rebuild from events anytime).
model IntegritySnapshot {
  id                  String   @id @default(cuid())
  businessId          String
  clientTransactionId String
  /// Last IntegrityLedgerEvent.eventId included in this snapshot (inclusive of ordered replay).
  lastEventId         String?
  eventCount          Int      @default(0)
  stateJson           Json
  /// Denormalized runningNet / recognition total for filtering (see stateJson for full state).
  balance             Float
  ledgerHash          String
  stateHash           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, clientTransactionId])
  @@index([businessId, createdAt])
}

model TransactionItem {
  id            String      @id @default(uuid())
  quantity      Float
  price         Float
  /// Product cost per sell unit at time of sale (kg/litre = per unit of measure).
  unitCostAtSale Float       @default(0)
  /// Line revenue before tax allocation (= abs(qty) * unit sell).
  lineSubtotal   Float       @default(0)
  lineCost       Float       @default(0)
  lineProfit     Float       @default(0)
  transactionId String
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@index([transactionId])
  @@index([productId])
}

model Settings {
  id             String   @id @default(uuid())
  countryCode    String   @default("US")
  currencyCode   String   @default("USD")
  currencySymbol String   @default("$")
  taxEnabled     Boolean  @default(false)
  taxRate        Float    @default(0)
  taxRules       Json?
  businessName   String
  businessEmail  String
  businessPhone  String?
  /// IANA time zone for “today” in daily summary / reporting (Phase 7.12.4), e.g. Africa/Lagos.
  businessTimeZone String @default("UTC")
  logoUrl        String?
  receiptLayout  String?  @default("STANDARD")
  /// Phase 7.11.2: product UUIDs to show first in Quick Sales (ordered).
  quickSalesProductIds Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  businessId     String   @unique
  business       Business @relation(fields: [businessId], references: [id])
}

/// DB-backed feature toggles (Phase 7.5); seeded in migration.
model FeatureFlag {
  id               String   @id @default(uuid())
  key              String   @unique
  label            String?
  freeEnabled      Boolean  @default(false)
  basicEnabled     Boolean  @default(false)
  premiumEnabled   Boolean  @default(false)
  abRolloutPercent Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model UsageMonthly {
  id              String   @id @default(uuid())
  businessId      String
  yearMonth       String
  apiRequestCount Int      @default(0)
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, yearMonth])
  @@index([businessId])
}

model Subscription {
  id           String             @id @default(uuid())
  plan         SubscriptionPlan   @default(FREE)
  status       SubscriptionStatus @default(ACTIVE)
  provider     String?
  externalRef  String?
  expiresAt    DateTime?
  featureFlags Json?
  usageLimits  Json?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  businessId   String             @unique
  /// Optional FREE trial end for new signups when BILLING_TRIAL_DAYS is set; null = legacy unlimited FREE.
  trialEndsAt  DateTime?
  business     Business           @relation(fields: [businessId], references: [id])
}

model OnboardingProgress {
  id               String   @id @default(uuid())
  firstProductDone Boolean  @default(false)
  firstSaleDone    Boolean  @default(false)
  lastActiveAt     DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  businessId       String   @unique
  business         Business @relation(fields: [businessId], references: [id])
}

model SmartAlert {
  id         String    @id @default(uuid())
  type       AlertType
  message    String
  alertDate  DateTime
  createdAt  DateTime  @default(now())
  businessId String
  business   Business  @relation(fields: [businessId], references: [id])

  @@unique([businessId, type, alertDate])
  @@index([businessId])
}

model PaymentHistory {
  id              String           @id @default(uuid())
  provider        String
  providerRef     String
  plan            SubscriptionPlan
  amount          Float
  currency        String           @default("USD")
  status          String
  paidAt          DateTime?
  createdAt       DateTime         @default(now())
  businessId      String
  /// API request id when checkout was created (correlation / support).
  clientRequestId String?
  /// Last gateway webhook event id applied to this row (if any).
  gatewayEventId  String?
  retryCount      Int              @default(0)
  lastAttemptAt   DateTime?
  /// When set, automated retry may run (exponential backoff from lastRetryAt).
  nextRetryAt     DateTime?
  failureReason   String?
  business        Business         @relation(fields: [businessId], references: [id])

  @@unique([provider, providerRef])
  @@index([businessId])
  @@index([status, nextRetryAt])
  @@index([clientRequestId])
}

/// Idempotent gateway event ledger (unique provider + dedupeKey = one processed delivery).
model BillingWebhookEvent {
  id         String   @id @default(uuid())
  provider   String
  dedupeKey  String
  businessId String?
  metadata   Json?
  createdAt  DateTime @default(now())
  /// SUCCESS | DUPLICATE | IGNORED | ERROR (best-effort for observability)
  outcome    String?  @default("SUCCESS")

  @@unique([provider, dedupeKey])
  @@index([businessId])
  @@index([createdAt])
}

model ActiveSession {
  id         String    @id @default(uuid())
  tokenJti   String    @unique
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?
  userId     String
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  metadata   Json?
  createdAt  DateTime @default(now())
  businessId String
  userId     String?
  business   Business @relation(fields: [businessId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])

  @@index([businessId, createdAt(sort: Desc)])
}

/// Immutable business audit trail (human accountability). Insert-only via bulk ingest; id = client UUID for dedupe.
model AuditEvent {
  id             String   @id
  businessId     String
  type           String
  actorId        String
  deviceId       String
  entityType     String
  entityId       String
  action         String
  before         Json?
  after          Json?
  source         String
  metadata       Json?
  /// Links multiple audit rows to one business action (checkout session, return, etc.).
  correlationId  String?
  createdAt      DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt(sort: Desc)])
  @@index([businessId, entityType, entityId])
  @@index([businessId, correlationId])
}

model BackupRecord {
  id              String   @id @default(uuid())
  filePath        String
  sizeBytes       Int
  status          String
  /// "SERVER" = Prisma JSON export; "INDEXEDDB" = full offline store snapshot from client.
  kind            String   @default("SERVER")
  createdByUserId String?
  createdAt       DateTime @default(now())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
}

model IssueReport {
  id          String   @id @default(uuid())
  subject     String
  description String
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  businessId  String
  userId      String?
  business    Business @relation(fields: [businessId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@index([businessId])
}

model playing_with_neon {
  id    Int    @id @default(autoincrement())
  name  String
  value Float? @db.Real
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
}

enum TransactionType {
  SALE
  RETURN
}

/// Resumable POS return pipeline (no state skipping).
enum SaleReturnState {
  RETURN_INITIATED
  RETURN_VALIDATED
  LEDGER_RECORDED
  INVENTORY_RESTORED
  REFUND_PROCESSED
  RETURN_COMPLETED
  RETURN_FAILED_VALIDATION
  RETURN_FAILED_LEDGER
  RETURN_FAILED_INVENTORY
  RETURN_FAILED_REFUND
}

enum LedgerEntryKind {
  RETURN_REVERSAL
}

/// Phase 4 SoR: how the integrity event reached the server.
enum LedgerIntegritySource {
  ONLINE
  OFFLINE
  SYNC
}

/// Phase 4 SoR: ledger line classification (projection rows).
enum IntegrityLedgerLineKind {
  SALE
  REFUND
  ADJUSTMENT
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  MOBILE
  CREDIT
  /// Multiple tender lines (see `payments` JSON).
  MULTI
}

/// POS sale credit state (do not confuse with billing PaymentHistory payment lifecycle).
enum TransactionPaymentStatus {
  PAID
  PARTIAL
  CREDIT
}

enum SyncStatus {
  PENDING
  SYNCED
  FAILED
}

enum SubscriptionPlan {
  FREE
  BASIC
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
}

enum AlertType {
  SALES_SPIKE
  SALES_DROP
}
