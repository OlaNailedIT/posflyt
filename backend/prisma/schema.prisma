// Schema changes: use `npm run prisma:migrate` (Prisma Migrate) locally, commit `migrations/`.
// Do not use `db push` for production; `npm run prisma:db-push-dev` is for local prototyping only.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id             String              @id @default(uuid())
  name           String
  createdAt      DateTime            @default(now())
  auditLogs      AuditLog[]
  backups        BackupRecord[]
  customers      Customer[]
  issues         IssueReport[]
  onboarding     OnboardingProgress?
  paymentHistory PaymentHistory[]
  products       Product[]
  settings       Settings?
  smartAlerts    SmartAlert[]
  stores         Store[]
  subscription   Subscription?
  transactions   Transaction[]
  users          User[]
  subscriptionLifecycleEvents SubscriptionLifecycleEvent[]
  usageMonthly                UsageMonthly[]
}

model User {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  password       String
  role           Role            @default(CASHIER)
  createdAt      DateTime        @default(now())
  businessId     String
  sessions       ActiveSession[]
  refreshTokens  RefreshToken[]
  auditLogs      AuditLog[]
  issues         IssueReport[]
  transactions   Transaction[]
  business       Business        @relation(fields: [businessId], references: [id])

  @@index([businessId])
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  sessionJti String?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Store {
  id           String        @id @default(uuid())
  name         String
  location     String?
  createdAt    DateTime      @default(now())
  businessId   String
  products     Product[]
  business     Business      @relation(fields: [businessId], references: [id])
  transactions Transaction[]

  @@index([businessId])
}

model Product {
  id                String            @id
  name              String
  costPrice         Float             @default(0)
  sellingPrice      Float             @default(0)
  price             Float
  stock             Int
  lowStockThreshold Int               @default(10)
  barcode           String?           @unique
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  businessId        String
  storeId           String?
  business          Business          @relation(fields: [businessId], references: [id])
  store             Store?            @relation(fields: [storeId], references: [id])
  transactionItems  TransactionItem[]

  @@index([businessId])
}

model Customer {
  id           String        @id @default(uuid())
  name         String
  email        String?
  phone        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  businessId   String
  business     Business      @relation(fields: [businessId], references: [id])
  transactions Transaction[]

  @@index([businessId])
  @@index([businessId, createdAt(sort: Desc)])
}

model Transaction {
  id            String            @id
  total         Float
  paymentMethod PaymentMethod
  createdAt     DateTime
  syncedAt      DateTime?
  syncStatus    SyncStatus        @default(PENDING)
  businessId    String
  userId        String
  storeId       String?
  customerId    String?
  business      Business          @relation(fields: [businessId], references: [id])
  customer      Customer?         @relation(fields: [customerId], references: [id])
  store         Store?            @relation(fields: [storeId], references: [id])
  user          User              @relation(fields: [userId], references: [id])
  items         TransactionItem[]

  // client_transaction_id is stored as `id`; idempotency scoped to business (ADR 003).
  @@unique([id, businessId], name: "client_transaction_id_business_id")
  @@index([businessId, createdAt(sort: Desc)])
}

model TransactionItem {
  id            String      @id @default(uuid())
  quantity      Int
  price         Float
  transactionId String
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@index([transactionId])
  @@index([productId])
}

model Settings {
  id             String   @id @default(uuid())
  countryCode    String   @default("US")
  currencyCode   String   @default("USD")
  currencySymbol String   @default("$")
  taxEnabled     Boolean  @default(false)
  taxRate        Float    @default(0)
  taxRules       Json?
  businessName   String
  businessEmail  String
  businessPhone  String?
  logoUrl        String?
  receiptLayout  String?  @default("STANDARD")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  businessId     String   @unique
  business       Business @relation(fields: [businessId], references: [id])
}

model Subscription {
  id           String             @id @default(uuid())
  plan         SubscriptionPlan   @default(FREE)
  status       SubscriptionStatus @default(ACTIVE)
  provider     String?
  externalRef  String?
  expiresAt    DateTime?
  /// Optional FREE trial end for new signups when BILLING_TRIAL_DAYS is set; null = legacy unlimited FREE.
  trialEndsAt  DateTime?
  /// After paid `expiresAt`, access may continue until this instant (Phase 7.4 grace).
  graceEndsAt  DateTime?
  /// User requested cancel at end of current period (MVP flag; renewal still applies via webhook).
  cancelAtPeriodEnd Boolean       @default(false)
  featureFlags Json?
  usageLimits  Json?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  businessId   String             @unique
  business     Business           @relation(fields: [businessId], references: [id])
}

/// Timestamped subscription / trial events for analytics and retention (Phase 7.4).
model SubscriptionLifecycleEvent {
  id         String   @id @default(uuid())
  businessId String
  eventType  String
  metadata   Json?
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt(sort: Desc)])
  @@index([eventType, createdAt(sort: Desc)])
}

model OnboardingProgress {
  id               String   @id @default(uuid())
  firstProductDone Boolean  @default(false)
  firstSaleDone    Boolean  @default(false)
  lastActiveAt     DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  businessId       String   @unique
  business         Business @relation(fields: [businessId], references: [id])
}

model SmartAlert {
  id         String    @id @default(uuid())
  type       AlertType
  message    String
  alertDate  DateTime
  createdAt  DateTime  @default(now())
  businessId String
  business   Business  @relation(fields: [businessId], references: [id])

  @@unique([businessId, type, alertDate])
  @@index([businessId])
}

model PaymentHistory {
  id          String           @id @default(uuid())
  provider    String
  providerRef String
  plan        SubscriptionPlan
  amount      Float
  /// Optional breakdown (e.g. pro-rata upgrade credit) for support and idempotent reconciliation.
  metadata    Json?
  currency    String           @default("USD")
  status      PaymentStatus    @default(pending)
  paidAt      DateTime?
  /// API request id when checkout was created (correlation / support).
  clientRequestId String?
  /// Last gateway webhook event id applied to this row (if any).
  gatewayEventId  String?
  /// Unique idempotency key per intent (Stripe/Paystack idempotency + local dedupe).
  idempotencyKey  String?        @unique
  retryCount      Int            @default(0)
  lastRetryAt     DateTime?
  /// When set, automated retry may run (exponential backoff from lastRetryAt).
  nextRetryAt     DateTime?
  failureReason   String?
  /// Stripe session / Paystack access_code / PI ids for reconciliation and retries.
  providerMetadata Json?
  createdAt       DateTime       @default(now())
  businessId      String
  business        Business       @relation(fields: [businessId], references: [id])

  @@unique([provider, providerRef])
  @@index([businessId])
  @@index([status, nextRetryAt])
  @@index([clientRequestId])
}

/// Idempotent gateway event ledger (unique provider + dedupeKey = one processed delivery).
model BillingWebhookEvent {
  id         String   @id @default(uuid())
  provider   String
  dedupeKey  String
  businessId String?
  metadata   Json?
  /// SUCCESS | DUPLICATE | IGNORED | ERROR (best-effort for observability)
  outcome    String?  @default("SUCCESS")
  createdAt  DateTime @default(now())

  @@unique([provider, dedupeKey])
  @@index([businessId])
  @@index([createdAt])
}

model ActiveSession {
  id         String    @id @default(uuid())
  tokenJti   String    @unique
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?
  userId     String
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  metadata   Json?
  createdAt  DateTime @default(now())
  businessId String
  userId     String?
  business   Business @relation(fields: [businessId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])

  @@index([businessId, createdAt(sort: Desc)])
  @@index([userId])
}

model BackupRecord {
  id         String   @id @default(uuid())
  filePath   String
  sizeBytes  Int
  status     String
  createdAt  DateTime @default(now())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
}

model IssueReport {
  id          String   @id @default(uuid())
  subject     String
  description String
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  businessId  String
  userId      String?
  business    Business @relation(fields: [businessId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@index([businessId])
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  MOBILE
}

enum SyncStatus {
  PENDING
  SYNCED
  FAILED
}

enum SubscriptionPlan {
  FREE
  BASIC
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
}

enum AlertType {
  SALES_SPIKE
  SALES_DROP
}

/// Gateway payment lifecycle (lowercase values for API consistency).
enum PaymentStatus {
  pending
  paid
  failed
  retrying
  canceled
}

/// Tier-based feature toggles (Phase 7.5). Editable without redeploy; optional A/B via `abRolloutPercent`.
model FeatureFlag {
  id                 String   @id @default(uuid())
  key                String   @unique
  label              String?
  freeEnabled        Boolean  @default(false)
  basicEnabled       Boolean  @default(false)
  premiumEnabled     Boolean  @default(false)
  /// When set (0–100), only that bucket of businesses per key sees the flag in addition to tier rules.
  abRolloutPercent   Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

/// Monthly API usage meter per business (Phase 7.5). Transaction/customer counts use live aggregates.
model UsageMonthly {
  id              String   @id @default(uuid())
  businessId      String
  yearMonth       String
  apiRequestCount Int      @default(0)
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, yearMonth])
  @@index([businessId])
}
