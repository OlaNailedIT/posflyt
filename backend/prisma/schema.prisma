generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id             String              @id @default(uuid())
  name           String
  createdAt      DateTime            @default(now())
  auditLogs      AuditLog[]
  backups        BackupRecord[]
  customers      Customer[]
  issues         IssueReport[]
  onboarding     OnboardingProgress?
  paymentHistory PaymentHistory[]
  products       Product[]
  lowStockAlertDays LowStockAlertDay[]
  settings       Settings?
  smartAlerts    SmartAlert[]
  stores         Store[]
  subscription   Subscription?
  transactions   Transaction[]
  expenses       Expense[]
  usageMonthly   UsageMonthly[]
  users          User[]
  dailyCloses    DailyClose[]
}

/// Phase 7.13.1: operational daily close log (not full accounting).
model DailyClose {
  id             String   @id @default(uuid())
  businessId     String
  userId         String
  totalSales     Float
  startOfDay     DateTime
  endOfDay       DateTime
  closedAt       DateTime @default(now())
  /// YYYY-MM-DD in business time zone (idempotency: one close per business day).
  businessDayKey String

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([businessId, businessDayKey])
  @@index([businessId])
  @@index([userId])
  @@index([closedAt(sort: Desc)])
}

/// Phase 7.10.2: simple business expenses (profit = sales − expenses; not stored as a column).
model Expense {
  id         String   @id @default(cuid())
  businessId String
  amount     Float
  category   String
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  requestId  String?  @unique
  eventId    String?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, eventId])
  @@index([businessId])
  @@index([createdAt])
}

model User {
  id            String          @id @default(uuid())
  name          String
  email         String          @unique
  password      String
  role          Role            @default(CASHIER)
  createdAt     DateTime        @default(now())
  businessId    String
  sessions      ActiveSession[]
  auditLogs     AuditLog[]
  issues        IssueReport[]
  refreshTokens RefreshToken[]
  transactions  Transaction[]
  dailyCloses   DailyClose[]
  business      Business        @relation(fields: [businessId], references: [id])

  @@index([businessId])
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  sessionJti String?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Store {
  id           String        @id @default(uuid())
  name         String
  location     String?
  createdAt    DateTime      @default(now())
  businessId   String
  products     Product[]
  business     Business      @relation(fields: [businessId], references: [id])
  transactions Transaction[]

  @@index([businessId])
}

model Product {
  id                String            @id
  name              String
  costPrice         Float             @default(0)
  sellingPrice      Float             @default(0)
  price             Float
  /// Phase 7.11.1: "unit" = discrete count; "kg" | "litre" = sold by weight/volume (fractional qty).
  unitType          String            @default("unit")
  /// Price per kg/litre when unitType is not "unit"; null for discrete products.
  pricePerUnit      Float?
  stock             Float
  /// Phase 7.11.3: alert when stock <= threshold; null or ≤0 = no alert for this product.
  lowStockThreshold Float?
  barcode           String?           @unique
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  businessId        String
  storeId           String?
  business          Business          @relation(fields: [businessId], references: [id])
  store             Store?            @relation(fields: [storeId], references: [id])
  transactionItems  TransactionItem[]
  lowStockAlertDays LowStockAlertDay[]

  @@index([businessId])
}

/// Phase 7.11.3: one dedupe row per product per UTC day when a low-stock alert fires (transaction or scan).
model LowStockAlertDay {
  id          String   @id @default(cuid())
  businessId  String
  productId   String
  dayUtc      String
  stock       Float
  threshold   Float
  source      String
  createdAt   DateTime @default(now())
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([businessId, productId, dayUtc])
  @@index([businessId])
}

model Customer {
  id               String        @id @default(uuid())
  name             String
  email            String?
  phone            String?
  createdAt        DateTime      @default(now())
  businessId       String
  updatedAt        DateTime      @default(now()) @updatedAt
  /// Sum of unpaid balances from credit / partial sales (server-maintained).
  totalOutstanding Float         @default(0)
  /// Idempotency key for aggregate settle (POST /customers/:id/settle-credit).
  lastCreditSettlementRequestId String?
  business         Business      @relation(fields: [businessId], references: [id])
  transactions     Transaction[]

  @@index([businessId])
}

model Transaction {
  id            String            @id
  /// Sale total (line items + tax); CHECK-aligned with amountPaid / balanceDue.
  totalAmount   Float
  /// Phase 7.10.4: split tender lines; sum of amounts equals totalAmount when set. Legacy rows null.
  payments      Json?
  paymentMethod PaymentMethod
  /// Sale payment lifecycle (distinct from billing PaymentHistory.status enum).
  paymentStatus TransactionPaymentStatus @default(PAID)
  amountPaid    Float             @default(0)
  balanceDue    Float             @default(0)
  dueDate       DateTime?
  createdAt     DateTime
  updatedAt     DateTime          @updatedAt
  syncedAt      DateTime?
  syncStatus    SyncStatus        @default(PENDING)
  /// Duplicate replay guard for credit settlement sync.
  lastSettlementRequestId String?
  /// Offline / sync event deduplication (optional client-provided id).
  lastProcessedEventId    String?
  /// Phase 7.12.1: receipt PDF id (filename base in storage).
  receiptId          String? @unique
  /// Shareable URL (API public route or hosted PDF).
  receiptUrl         String?
  /// Opaque token for unauthenticated GET /receipts/public/:token.
  receiptPublicToken String? @unique
  businessId    String
  userId        String
  storeId       String?
  customerId    String?
  business      Business          @relation(fields: [businessId], references: [id])
  customer      Customer?         @relation(fields: [customerId], references: [id])
  store         Store?            @relation(fields: [storeId], references: [id])
  user          User              @relation(fields: [userId], references: [id])
  items         TransactionItem[]

  @@unique([id, businessId], map: "Transaction_client_transaction_id_business_id_key")
  @@index([businessId])
  @@index([businessId, createdAt(sort: Desc)])
}

model TransactionItem {
  id            String      @id @default(uuid())
  quantity      Float
  price         Float
  transactionId String
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@index([transactionId])
  @@index([productId])
}

model Settings {
  id             String   @id @default(uuid())
  countryCode    String   @default("US")
  currencyCode   String   @default("USD")
  currencySymbol String   @default("$")
  taxEnabled     Boolean  @default(false)
  taxRate        Float    @default(0)
  taxRules       Json?
  businessName   String
  businessEmail  String
  businessPhone  String?
  /// IANA time zone for “today” in daily summary / reporting (Phase 7.12.4), e.g. Africa/Lagos.
  businessTimeZone String @default("UTC")
  logoUrl        String?
  receiptLayout  String?  @default("STANDARD")
  /// Phase 7.11.2: product UUIDs to show first in Quick Sales (ordered).
  quickSalesProductIds Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  businessId     String   @unique
  business       Business @relation(fields: [businessId], references: [id])
}

/// DB-backed feature toggles (Phase 7.5); seeded in migration.
model FeatureFlag {
  id               String   @id @default(uuid())
  key              String   @unique
  label            String?
  freeEnabled      Boolean  @default(false)
  basicEnabled     Boolean  @default(false)
  premiumEnabled   Boolean  @default(false)
  abRolloutPercent Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model UsageMonthly {
  id              String   @id @default(uuid())
  businessId      String
  yearMonth       String
  apiRequestCount Int      @default(0)
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, yearMonth])
  @@index([businessId])
}

model Subscription {
  id           String             @id @default(uuid())
  plan         SubscriptionPlan   @default(FREE)
  status       SubscriptionStatus @default(ACTIVE)
  provider     String?
  externalRef  String?
  expiresAt    DateTime?
  featureFlags Json?
  usageLimits  Json?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  businessId   String             @unique
  /// Optional FREE trial end for new signups when BILLING_TRIAL_DAYS is set; null = legacy unlimited FREE.
  trialEndsAt  DateTime?
  business     Business           @relation(fields: [businessId], references: [id])
}

model OnboardingProgress {
  id               String   @id @default(uuid())
  firstProductDone Boolean  @default(false)
  firstSaleDone    Boolean  @default(false)
  lastActiveAt     DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  businessId       String   @unique
  business         Business @relation(fields: [businessId], references: [id])
}

model SmartAlert {
  id         String    @id @default(uuid())
  type       AlertType
  message    String
  alertDate  DateTime
  createdAt  DateTime  @default(now())
  businessId String
  business   Business  @relation(fields: [businessId], references: [id])

  @@unique([businessId, type, alertDate])
  @@index([businessId])
}

model PaymentHistory {
  id              String           @id @default(uuid())
  provider        String
  providerRef     String
  plan            SubscriptionPlan
  amount          Float
  currency        String           @default("USD")
  status          String
  paidAt          DateTime?
  createdAt       DateTime         @default(now())
  businessId      String
  /// API request id when checkout was created (correlation / support).
  clientRequestId String?
  /// Last gateway webhook event id applied to this row (if any).
  gatewayEventId  String?
  retryCount      Int              @default(0)
  lastAttemptAt   DateTime?
  /// When set, automated retry may run (exponential backoff from lastRetryAt).
  nextRetryAt     DateTime?
  failureReason   String?
  business        Business         @relation(fields: [businessId], references: [id])

  @@unique([provider, providerRef])
  @@index([businessId])
  @@index([status, nextRetryAt])
  @@index([clientRequestId])
}

/// Idempotent gateway event ledger (unique provider + dedupeKey = one processed delivery).
model BillingWebhookEvent {
  id         String   @id @default(uuid())
  provider   String
  dedupeKey  String
  businessId String?
  metadata   Json?
  createdAt  DateTime @default(now())
  /// SUCCESS | DUPLICATE | IGNORED | ERROR (best-effort for observability)
  outcome    String?  @default("SUCCESS")

  @@unique([provider, dedupeKey])
  @@index([businessId])
  @@index([createdAt])
}

model ActiveSession {
  id         String    @id @default(uuid())
  tokenJti   String    @unique
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?
  userId     String
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  metadata   Json?
  createdAt  DateTime @default(now())
  businessId String
  userId     String?
  business   Business @relation(fields: [businessId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])

  @@index([businessId, createdAt(sort: Desc)])
}

model BackupRecord {
  id              String   @id @default(uuid())
  filePath        String
  sizeBytes       Int
  status          String
  /// "SERVER" = Prisma JSON export; "INDEXEDDB" = full offline store snapshot from client.
  kind            String   @default("SERVER")
  createdByUserId String?
  createdAt       DateTime @default(now())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
}

model IssueReport {
  id          String   @id @default(uuid())
  subject     String
  description String
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  businessId  String
  userId      String?
  business    Business @relation(fields: [businessId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@index([businessId])
}

model playing_with_neon {
  id    Int    @id @default(autoincrement())
  name  String
  value Float? @db.Real
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  MOBILE
  CREDIT
  /// Multiple tender lines (see `payments` JSON).
  MULTI
}

/// POS sale credit state (do not confuse with billing PaymentHistory payment lifecycle).
enum TransactionPaymentStatus {
  PAID
  PARTIAL
  CREDIT
}

enum SyncStatus {
  PENDING
  SYNCED
  FAILED
}

enum SubscriptionPlan {
  FREE
  BASIC
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
}

enum AlertType {
  SALES_SPIKE
  SALES_DROP
}
